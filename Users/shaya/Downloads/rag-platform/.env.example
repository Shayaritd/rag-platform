ENV=local
LOG_LEVEL=INFO

# Postgres — or a Supabase connection string, e.g.
# postgresql+psycopg://postgres:[password]@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/rag_platform

JWT_SECRET=replace-with-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
LLAMA_BASE_URL=http://host.docker.internal:11434
LLAMA_MODEL=llama3

DEFAULT_DAILY_QUERY_QUOTA=200
RATE_LIMIT_PER_MINUTE=30

UPLOAD_DIR=/data/uploads
MAX_UPLOAD_MB=25
QUERY_CACHE_TTL_SECONDS=3600
