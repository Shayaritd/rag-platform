services:
  postgres:
    image: postgres:16-alpine
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres
      POSTGRES_DB: rag_platform
    ports: ["5432:5432"]
    volumes: ["pgdata:/var/lib/postgresql/data"]
    # Swap this service out entirely if using Supabase — just point
    # DATABASE_URL in .env at your Supabase connection string instead.

  redis:
    image: redis:7-alpine
    ports: ["6379:6379"]

  qdrant:
    image: qdrant/qdrant:latest
    ports: ["6333:6333"]
    volumes: ["qdrant_data:/qdrant/storage"]

  api:
    build: { context: ., dockerfile: api/Dockerfile }
    env_file: .env
    ports: ["8000:8000"]
    depends_on: [postgres, redis, qdrant]
    volumes: ["uploads:/data/uploads"]

  worker:
    build: { context: ., dockerfile: worker/Dockerfile }
    env_file: .env
    depends_on: [postgres, redis, qdrant]
    volumes: ["uploads:/data/uploads"]

  dashboard:
    build: { context: dashboard }
    ports: ["8501:8501"]
    environment:
      API_BASE: "http://api:8000/api/v1"
    depends_on: [api]

  prometheus:
    image: prom/prometheus:latest
    volumes: ["./monitoring/prometheus.yml:/etc/prometheus/prometheus.yml"]
    ports: ["9090:9090"]
    depends_on: [api]

  grafana:
    image: grafana/grafana:latest
    ports: ["3000:3000"]
    depends_on: [prometheus]

volumes:
  pgdata:
  qdrant_data:
  uploads:
